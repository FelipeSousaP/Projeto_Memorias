        },
        {
            "m_Id": "48886bc55f2a442599d265876c059ac0"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "MainLight",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#ifdef UNIVERSAL_LIGHTING_INCLUDED\r\n    // Versão compatível com as novas URPs\r\n    float4 shadowCoord = TransformWorldToShadowCoord(WorldPos);\r\n    Light light = GetMainLight(shadowCoord);\r\n    \r\n    Direction = light.direction;\r\n    Color = light.color;\r\n    DistanceAtten = light.distanceAttenuation;\r\n    ShadowAtten = light.shadowAttenuation;\r\n#else\r\n    // Fallback para o Preview\r\n    Direction = float3(0.5, 0.5, 0);\r\n    Color = float3(1, 1, 1);\r\n    DistanceAtten = 1.0;\r\n    ShadowAtten = 1.0;\r\n#endif"
}

